# 노션 매출 연동용 (BFF에서만 사용 — 브라우저에 노출 금지)
# 실제 값은 .env 에 넣으세요 (.env 는 git 에 커밋되지 않습니다).

# 1) 노션 통합(integration) 시크릿 토큰  ← 이것만 직접 발급하면 됩니다
#    https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) 매출 DB의 ID  ← 모르면 `node server/notion-inspect.mjs` 가 찾아줍니다
NOTION_SALES_DB_ID=

# 3) 날짜/금액 속성 이름  ← 비워두면 BFF가 타입 보고 자동 감지합니다
NOTION_DATE_PROP=
NOTION_AMOUNT_PROP=

# BFF 포트
BFF_PORT=8787

# KOVAN CATECA 로그인 (일별 TR현황 자동 수집용 — 채팅에 붙이지 말고 여기에만)
KOVAN_ID=
KOVAN_PW=
KOVAN_AGENCY=A25700
# 거래종류: A=카드+현금, B=카드, C=현금
KOVAN_TRAN=B

# DDWM (다우데이타 VAN) — van.daoudata.co.kr
DDWM_ID=
DDWM_PW=

# Gmail 인증번호 자동 읽기 (DDWM 이메일 2단계 인증)
GMAIL_USER=dain@daininc.kr
GMAIL_APP_PASSWORD=

# 국세청 사업자등록 상태조회 (공공데이터포털 data.go.kr 인증키)
NTS_API_KEY=

# 채널톡(Channel.io) Open API — 채널 설정 > 보안 및 개발 > Open API
CHANNELTALK_ACCESS_KEY=
CHANNELTALK_ACCESS_SECRET=
