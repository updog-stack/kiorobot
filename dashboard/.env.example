# 노션 매출 연동용 (BFF에서만 사용 — 브라우저에 노출 금지)
# 실제 값은 .env 에 넣으세요 (.env 는 git 에 커밋되지 않습니다).

# 1) 노션 통합(integration) 시크릿 토큰  ← 이것만 직접 발급하면 됩니다
#    https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) 매출 DB의 ID  ← 모르면 `node server/notion-inspect.mjs` 가 찾아줍니다
NOTION_SALES_DB_ID=

# 3) 날짜/금액 속성 이름  ← 비워두면 BFF가 타입 보고 자동 감지합니다
NOTION_DATE_PROP=
NOTION_AMOUNT_PROP=

# BFF 포트
BFF_PORT=8787

# ───────── 접근제어(로그인) — 외부 서버 오픈 시 필수 ─────────
# APP_PASSWORD : 대시보드 접속 비밀번호(전 직원 공용 1개). 비워두면 로그인 비활성(개발용).
#   외부 서버 배포 시 반드시 설정하세요.
APP_PASSWORD=
# SESSION_SECRET : 세션 쿠키 서명 키(아무 긴 무작위 문자열). 미설정 시 재시작마다 전원 재로그인.
#   생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# KOVAN CATECA 로그인 (일별 TR현황 자동 수집용 — 채팅에 붙이지 말고 여기에만)
KOVAN_ID=
KOVAN_PW=
KOVAN_AGENCY=A25700
# 거래종류: A=카드+현금, B=카드, C=현금
KOVAN_TRAN=B

# DDWM (다우데이타 VAN) — van.daoudata.co.kr
DDWM_ID=
DDWM_PW=

# Gmail 인증번호 자동 읽기 (DDWM 이메일 2단계 인증)
GMAIL_USER=dain@daininc.kr
GMAIL_APP_PASSWORD=

# 국세청 사업자등록 상태조회 (공공데이터포털 data.go.kr 인증키)
NTS_API_KEY=

# 채널톡(Channel.io) Open API — 채널 설정 > 보안 및 개발 > Open API
CHANNELTALK_ACCESS_KEY=
CHANNELTALK_ACCESS_SECRET=

# 구글캘린더(일정 탭)
# 방식 A(읽기 전용·간단): 캘린더 설정 > '캘린더 통합' > 'iCal 형식의 비공개 주소'
GOOGLE_CALENDAR_ICS_URL=
# 방식 B(양방향·서비스계정): ERP에서 생성·수정·삭제 + 실시간 동기화. 설정되면 A보다 우선.
#   서비스계정을 각 캘린더에 '변경 및 관리 권한'으로 공유 필요.
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
# 대상 캘린더들: "라벨|캘린더ID" 콤마 구분
GOOGLE_CALENDARS=

# 유튜브 채널 지표(전체현황 카드) — YouTube Data API v3
#   YOUTUBE_API_KEY : 구글 클라우드 → YouTube Data API v3 사용 설정 → API 키 생성(서비스계정 아님)
#   YOUTUBE_CHANNEL : 채널ID(UC…로 시작) 또는 핸들(@채널핸들)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL=

# 업무일지 → 대표님 슬랙 전송 (PDF)
#   SLACK_BOT_TOKEN   : Slack 앱 봇 토큰(xoxb-...). 스코프: files:write, chat:write
#   SLACK_CEO_CHANNEL : 전송 대상 채널ID 또는 대표님 DM 채널ID (C... 또는 D...)
SLACK_BOT_TOKEN=
SLACK_CEO_CHANNEL=
